  "operation_groups": [
    {
      "id": "identity",
      "name": "Identity Operations",
      "operations": ["Passthrough", "ColorMatrix", "Arithmetic"],
      "description": "No pixel math or simple LUT-able transforms. Use source format directly.",
      "default_clamp": "N/A",
      "intent": "Fastest"
    },
    {
      "id": "linear_math",
      "name": "Linear-Light Math",
      "operations": ["ResizeGentle", "ResizeSharp", "OklabSharpen", "OklabAdjust", "Tonemap", "IccTransform"],
      "description": "Operations requiring gamma-correct math in linear light. f32 Linear required (f32 mandatory for ResizeSharp/OklabSharpen/OklabAdjust/Tonemap/IccTransform, preferred for ResizeGentle).",
      "default_clamp": "unclamped",
      "clamp_notes": "ResizeSharp: MUST be unclamped (Lanczos/CatmullRom overshoot). ResizeGentle: unclamped OK (Mitchell minor overshoot). Others: clamp to [0,1] after operation.",
      "intent": "LinearLight"
    },
    {
      "id": "soft_filter",
      "name": "Soft Filters",
      "operations": ["Blur", "Sharpen"],
      "description": "Convolution filters where gamma error is negligible. sRGB u8 acceptable, avoiding conversion overhead.",
      "default_clamp": "clamped",
      "intent": "Fastest"
    },
    {
      "id": "composite",
      "name": "Compositing",
      "operations": ["Composite"],
      "description": "Porter-Duff compositing and blend modes. REQUIRES f32 Linear with Premultiplied alpha for correct results. Non-alpha sources get opaque alpha added.",
      "default_clamp": "clamped [0,1]",
      "intent": "Blend"
    },
    {
      "id": "quantize",
      "name": "Palette Quantization",
      "operations": ["Quantize"],
      "description": "GIF palette quantization. REQUIRES sRGB u8 for perceptual distance metrics.",
      "default_clamp": "clamped [0,255]",
      "intent": "Fastest"
    }
  ],
  "clamp_rules": {
    "summary": "Integer formats (u8, u16) implicitly clamp to their range. Float formats (f32) can store values outside [0,1]. Clamp to valid range before encoding to integer-backed codecs.",
    "unclamped_required": [
      "ResizeSharp (Lanczos/CatmullRom overshoot from ringing — clamping causes visible banding at edges)",
      "JPEG extended f32 decode (IDCT ringing preserved for higher quality re-encoding)",
      "HDR content (PQ/HLG can encode >1.0 for highlights)"
    ],
    "clamp_before_encode": "Always clamp to codec's valid range before encoding. Exceptions: JXL lossless and PNM PFM can store arbitrary float values.",
    "clamp_after_operation": "Blur, Sharpen, Composite, OklabAdjust, Tonemap, IccTransform should clamp output to [0,1] before passing to next stage. ResizeGentle/ResizeSharp should NOT clamp (preserve overshoot for final encode clamp)."
  },
